generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkType {
  OFFICE
  DRIVER
  STUDENT
  LABORER
  ENTREPRENEUR
  HEALTHCARE
  HOSPITALITY
  REMOTE
  OTHER
}

enum GoalCategory {
  FITNESS
  SPIRITUAL_GROWTH
  RELATIONSHIPS
  EDUCATION
  CAREER
  FINANCE
  MENTAL_WELLBEING
  SOCIAL_WELLBEING
}

enum ProviderType {
  SPA
  WATER_PARK
  GYM
  YOGA
  MASSAGE
  RETREAT
  SPORTS
  COMMUNITY
  NUTRITION
}

enum LeadStatus {
  NEW
  CONTACTED
  BOOKED
  CLOSED
  CANCELLED
}

enum PassportActivityType {
  WALKING
  EXERCISE
  MEDITATION
  COMMUNITY_PARTICIPATION
  WELLNESS_EVENT
  PROVIDER_VISIT
}

model User {
  id                 String                @id @default(cuid())
  name               String
  email              String                @unique
  passwordHash       String                @default("")
  age                Int?
  gender             String?
  city               String?
  country            String                @default("Ethiopia")
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  assessments        WellnessAssessment[]
  fitnessPlans       FitnessPlan[]
  socialProfiles     SocialProfile[]
  growthGoals        GrowthGoal[]
  providerLeads      ProviderLead[]
  passportActivities PassportActivity[]
}

model WellnessAssessment {
  id                     String          @id @default(cuid())
  userId                 String
  workType               WorkType
  sleepHours             Float
  stressLevel            Int
  socialActivityLevel    Int
  exerciseMinutesPerWeek Int
  nutritionQuality       Int
  goals                  String[]
  wellnessScore          Int
  physicalScore          Int
  mentalScore            Int
  socialScore            Int
  growthScore            Int
  riskAlerts             String[]
  createdAt              DateTime        @default(now())
  user                   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  coachPlans             CoachPlan[]
  recommendations        Recommendation[]

  @@index([userId, createdAt])
}

model CoachPlan {
  id           String             @id @default(cuid())
  assessmentId String
  dailyRoutine String[]
  weeklyRoutine String[]
  habits       String[]
  riskAlerts   String[]
  summary      String
  createdAt    DateTime           @default(now())
  assessment   WellnessAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model FitnessPlan {
  id                  String   @id @default(cuid())
  userId              String
  heightCm            Float
  weightKg            Float
  bmi                 Float
  activityLevel       String
  goal                String
  workoutPlan         String[]
  waterLitersPerDay   Float
  mealSuggestions     String[]
  weeklyProgressNotes String?
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SocialProfile {
  id                  String   @id @default(cuid())
  userId              String
  tendency            String
  mood                String
  lonelinessLevel     Int
  interests           String[]
  recommendations     String[]
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GrowthGoal {
  id          String       @id @default(cuid())
  userId      String
  category    GoalCategory
  statement   String
  milestones  String[]
  nextActions String[]
  targetDate  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Provider {
  id          String          @id @default(cuid())
  name        String
  type        ProviderType
  city        String
  address     String?
  latitude    Float?
  longitude   Float?
  phone       String?
  website     String?
  offers      ProviderOffer[]
  leads       ProviderLead[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([name, city])
}

model ProviderOffer {
  id          String      @id @default(cuid())
  providerId  String
  title       String
  description String
  price       Decimal?
  pointsCost  Int?
  active      Boolean     @default(true)
  provider    Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]
}

model Recommendation {
  id           String             @id @default(cuid())
  assessmentId String
  offerId      String
  reason       String
  priority     Int                @default(1)
  createdAt    DateTime           @default(now())
  assessment   WellnessAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  offer        ProviderOffer      @relation(fields: [offerId], references: [id], onDelete: Cascade)
}

model ProviderLead {
  id         String     @id @default(cuid())
  userId     String
  providerId String
  status     LeadStatus @default(NEW)
  note       String?
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   Provider   @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model PassportActivity {
  id          String               @id @default(cuid())
  userId      String
  type        PassportActivityType
  description String
  points      Int
  occurredAt  DateTime             @default(now())
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
}
